<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_field"
        android:paddingTop="@dimen/spacing_small"
        android:paddingBottom="@dimen/spacing_field">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textinputActivityTitle"
            style="@style/Widget.Renvest.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/dialog_activity_title_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edittextActivityTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textinputActivitySubtitle"
            style="@style/Widget.Renvest.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_field"
            android:hint="@string/dialog_activity_subtitle_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edittextActivitySubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
