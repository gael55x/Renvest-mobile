<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Renvest" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Renvest" parent="Base.Theme.Renvest" />

    <style name="Widget.Renvest.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner</item>
    </style>

    <style name="Widget.Renvest.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/input_corner</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.TitleMedium</item>
    </style>

    <style name="Widget.Renvest.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Renvest.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/input_corner</item>
    </style>
</resources>
