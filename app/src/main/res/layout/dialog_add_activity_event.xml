<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_field"
        android:paddingTop="@dimen/spacing_small"
        android:paddingBottom="@dimen/spacing_field">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_activity_type_label"
            android:textAppearance="@style/TextAppearance.Renvest.Label" />

        <Spinner
            android:id="@+id/spinnerActivityType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_field"
            android:text="@string/dialog_activity_customer_label"
            android:textAppearance="@style/TextAppearance.Renvest.Label" />

        <Spinner
            android:id="@+id/spinnerActivityCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:minHeight="48dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textinputActivityTitle"
            style="@style/Widget.Renvest.TextInput.Dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_field"
            android:hint="@string/dialog_activity_title_hint"
            app:placeholderText="@string/dialog_activity_title_placeholder"
            app:startIconDrawable="@drawable/ic_notifications_24">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edittextActivityTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textinputActivitySubtitle"
            style="@style/Widget.Renvest.TextInput.Dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_field"
            android:hint="@string/dialog_activity_subtitle_hint"
            app:placeholderText="@string/dialog_activity_subtitle_placeholder"
            app:startIconDrawable="@drawable/ic_edit_24">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edittextActivitySubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
