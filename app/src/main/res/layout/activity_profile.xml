<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_screen_horizontal"
        android:paddingTop="@dimen/padding_screen_vertical"
        android:paddingBottom="@dimen/spacing_field">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textviewHeaderBusiness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Renvest.Caption"
                tools:text="@string/default_business_display" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/profile_title"
                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/buttonProfileOverflow"
            android:layout_width="@dimen/header_icon_size"
            android:layout_height="@dimen/header_icon_size"
            android:background="@drawable/bg_circle_surface_stroke"
            android:contentDescription="@string/content_desc_more_options"
            app:srcCompat="@drawable/ic_more_vert_24"
            app:tint="@color/text_primary" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingHorizontal="@dimen/padding_screen_horizontal"
        android:paddingBottom="@dimen/spacing_field">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/dashboard_hero"
                app:cardCornerRadius="@dimen/card_corner_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/grid_3">

                    <ImageButton
                        android:id="@+id/buttonProfileHeroEdit"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_circle_outline_white"
                        android:contentDescription="@string/content_desc_edit_business"
                        android:padding="@dimen/spacing_small"
                        app:srcCompat="@drawable/ic_edit_24"
                        app:tint="@color/on_dashboard_hero" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="48dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_profile_avatar_square">

                                <TextView
                                    android:id="@+id/textviewProfileHeroInitials"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/on_dashboard_hero"
                                    android:textStyle="bold"
                                    tools:text="CS" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_field"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/textviewProfileHeroBusinessName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/on_dashboard_hero"
                                    android:textStyle="bold"
                                    tools:text="@string/default_business_display" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/spacing_xs"
                                    android:text="@string/profile_hero_subtitle"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/dashboard_hero_subtle" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/spacing_small"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="@dimen/spacing_small"
                                    android:paddingVertical="@dimen/spacing_xs"
                                    android:background="@drawable/bg_profile_status_pill">

                                    <View
                                        android:layout_width="6dp"
                                        android:layout_height="6dp"
                                        android:background="@drawable/bg_dot_white" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="@dimen/spacing_xs"
                                        android:text="@string/profile_status_active_pro"
                                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                        android:textColor="@color/on_dashboard_hero" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Renvest.StatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_field">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/spacing_field">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textviewProfileStatMembers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_stat_members_value"
                            android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/profile_stats_members"
                            android:textAppearance="@style/TextAppearance.Renvest.Caption" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/outline_soft" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textviewProfileStatReturn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_stat_return_value"
                            android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/dashboard_stat_return_label"
                            android:textAppearance="@style/TextAppearance.Renvest.Caption" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/outline_soft" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textviewProfileStatPromos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/promo_stat_active_value"
                            android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/profile_stats_active_promos"
                            android:textAppearance="@style/TextAppearance.Renvest.Caption" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/grid_3"
                android:letterSpacing="0.04"
                android:text="@string/profile_section_business_settings"
                android:textAppearance="@style/TextAppearance.Renvest.Caption"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Renvest.StatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowSettingsBusinessName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_field">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/perf_icon_bg_people">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_home_24"
                                app:tint="@color/primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_field"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_settings_business_name"
                                android:textAppearance="@style/TextAppearance.Renvest.Caption" />

                            <TextView
                                android:id="@+id/textviewProfileRowBusinessValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                                android:textSize="15sp"
                                tools:text="@string/default_business_display" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/grid_3"
                            android:layout_height="@dimen/grid_3"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_soft" />

                    <LinearLayout
                        android:id="@+id/rowSettingsBusinessType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_field">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/perf_icon_bg_money">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_work_24"
                                app:tint="@color/badge_silver_text" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_field"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_settings_business_type"
                                android:textAppearance="@style/TextAppearance.Renvest.Caption" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/profile_settings_business_type_value"
                                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/grid_3"
                            android:layout_height="@dimen/grid_3"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_soft" />

                    <LinearLayout
                        android:id="@+id/rowSettingsEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_field">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/perf_icon_bg_star">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_mail_24"
                                app:tint="@color/badge_gold_text" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_field"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_settings_email"
                                android:textAppearance="@style/TextAppearance.Renvest.Caption" />

                            <TextView
                                android:id="@+id/textviewProfileRowEmailValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                                android:textSize="15sp"
                                tools:text="@string/profile_email_placeholder" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/grid_3"
                            android:layout_height="@dimen/grid_3"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_soft" />

                    <LinearLayout
                        android:id="@+id/rowSettingsLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_field">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/settings_icon_muted_bg">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_location_on_24"
                                app:tint="@color/text_secondary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_field"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_settings_location"
                                android:textAppearance="@style/TextAppearance.Renvest.Caption" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/profile_settings_location_value"
                                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/grid_3"
                            android:layout_height="@dimen/grid_3"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/grid_3"
                android:letterSpacing="0.04"
                android:text="@string/profile_section_loyalty_settings"
                android:textAppearance="@style/TextAppearance.Renvest.Caption"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Renvest.StatCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowLoyaltyThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_field">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/perf_icon_bg_people">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_promo_star_24"
                                app:tint="@color/primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_field"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_loyalty_reward_threshold"
                                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/profile_loyalty_reward_sub"
                                android:textAppearance="@style/TextAppearance.Renvest.Caption" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_xs"
                            android:background="@drawable/bg_badge_promo_active"
                            android:paddingHorizontal="@dimen/spacing_small"
                            android:paddingVertical="@dimen/spacing_xs"
                            android:text="@string/profile_loyalty_threshold_chip"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/grid_3"
                            android:layout_height="@dimen/grid_3"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_soft" />

                    <LinearLayout
                        android:id="@+id/rowLoyaltyPointsMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_field">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/perf_icon_bg_money">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                app:srcCompat="@drawable/ic_attach_money_24"
                                app:tint="@color/badge_silver_text" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_field"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/profile_loyalty_points_mode"
                                android:textAppearance="@style/TextAppearance.Renvest.SectionTitle"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/profile_loyalty_points_sub"
                                android:textAppearance="@style/TextAppearance.Renvest.Caption" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/spacing_xs"
                            android:background="@drawable/bg_badge_silver"
                            android:paddingHorizontal="@dimen/spacing_small"
                            android:paddingVertical="@dimen/spacing_xs"
                            android:text="@string/profile_loyalty_mode_chip"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="@color/badge_silver_text"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/grid_3"
                            android:layout_height="@dimen/grid_3"
                            android:contentDescription="@null"
                            app:srcCompat="@drawable/ic_chevron_right_24"
                            app:tint="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLogout"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/grid_3"
                android:minHeight="52dp"
                android:text="@string/action_logout"
                android:textAllCaps="false"
                android:textColor="@color/logout_text"
                app:rippleColor="@color/outline_soft" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomnavigationMain"
        style="@style/Widget.Renvest.BottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_nav_main" />
</LinearLayout>
