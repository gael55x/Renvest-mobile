<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_field">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textinputCustomerName"
        style="@style/Widget.Renvest.TextInput.Dialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dialog_customer_name_hint"
        app:placeholderText="@string/dialog_customer_name_placeholder"
        app:startIconDrawable="@drawable/ic_person_24">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edittextCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName|textCapWords"
            android:maxLines="2" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
